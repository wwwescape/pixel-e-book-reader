<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Only used for the window background shown before Compose renders; all real UI theming is done in ui/theme/Theme.kt -->
    <style name="Theme.PixelEBookReader" parent="Theme.Material3.DayNight.NoActionBar" />

    <!-- Shown by MainActivity only, via installSplashScreen(); hands off to Theme.PixelEBookReader once the first frame is ready. -->
    <style name="Theme.PixelEBookReader.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.PixelEBookReader</item>
    </style>
</resources>
