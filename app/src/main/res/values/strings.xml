    <string name="settings_row_licenses_subtitle">Libraries this app is built on</string>
    <string name="section_licenses_intro_title">Built with open source</string>
    <string name="section_licenses_intro_body">Pixel E-Book Reader is built using the following open-source libraries. Tap any entry to view its license.</string>
    <string name="licenses_footer_format">%1$s — %2$d</string>
    <string name="library_version_license_format">%1$s · %2$s</string>
    <string name="license_badge_apache">Apache 2.0</string>
    <string name="license_badge_mit">MIT</string>
    <string name="license_badge_bsd2">BSD-2-Clause</string>
    <string name="lib_desc_compose">Modern declarative UI toolkit — every screen in this app is built with it.</string>
    <string name="lib_desc_room">SQLite persistence for the library catalog: books, categories, history, color presets, and reading sessions.</string>
    <string name="lib_desc_jsoup">HTML/XML parsing — powers the EPUB, FB2, and HTML/HTM format parsers.</string>
    <string name="lib_desc_commonmark">Markdown parsing for the .md format parser.</string>
    <string name="lib_desc_pdfbox">PDF parsing and rendering for the .pdf format parser.</string>

