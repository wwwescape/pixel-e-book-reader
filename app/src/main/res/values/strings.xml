    <string name="about_version">Version %1$s</string>
    <string name="about_app_description">A modern e-book reader for PDF, EPUB, FB2, TXT, HTML, and Markdown, with deep reader customization, reading statistics, and text-to-speech — everything staying on your device.</string>
